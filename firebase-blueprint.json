{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user with specific roles",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["ADMIN", "JUDGE", "PARTICIPANT"] },
        "displayName": { "type": "string" },
        "teamId": { "type": "string", "description": "Optional link to a team for participants" }
      },
      "required": ["email", "role"]
    },
    "Team": {
      "title": "Team",
      "description": "Competition team",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string", "enum": ["JUNIOR", "SENIOR"] },
        "institution": { "type": "string" },
        "ownerId": { "type": "string", "description": "UID of the user who created the team" },
        "members": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "age": { "type": "number" }
            }
          }
        }
      },
      "required": ["name", "category", "ownerId"]
    },
    "MatchRound": {
      "title": "Match Round",
      "description": "A single scoring session for a team match",
      "type": "object",
      "properties": {
        "teamId": { "type": "string" },
        "judgeId": { "type": "string" },
        "matchNumber": { "type": "string" },
        "tableNumber": { "type": "string" },
        "roundNumber": { "type": "number" },
        "category": { "type": "string", "enum": ["JUNIOR", "SENIOR"] },
        "activePlots": {
          "type": "array",
          "items": { "type": "string", "enum": ["ORANGE", "GRAY", "GREEN"] }
        },
        "mission1": {
          "type": "object",
          "properties": {
            "correctSeeds": { "type": "number" },
            "seedsInCells": { "type": "number", "description": "Senior only" },
            "misplacedSeeds": { "type": "number" },
            "wateredSeededPlots": { "type": "number" },
            "wateredUnseededPlots": { "type": "number" }
          }
        },
        "mission2": {
          "type": "object",
          "properties": {
            "redBlackOffMarker": { "type": "number" },
            "redInFruits": { "type": "number" },
            "redInWaste": { "type": "number" },
            "blackInWaste": { "type": "number" },
            "blackInFruits": { "type": "number" },
            "greenOffCircle": { "type": "number" }
          }
        },
        "penalties": {
          "type": "object",
          "properties": {
            "unauthorizedInteraction": { "type": "number" },
            "manipulatingField": { "type": "number" },
            "handingSeedsOutside": { "type": "number" },
            "robotExitsField": { "type": "number" },
            "damageRefDecision": { "type": "number" },
            "disqualified": { "type": "boolean" }
          }
        },
        "totalScore": { "type": "number" },
        "status": { "type": "string", "enum": ["DRAFT", "FINAL"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["teamId", "judgeId", "category", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and roles"
    },
    "/teams/{teamId}": {
      "schema": "Team",
      "description": "Participating teams"
    },
    "/rounds/{roundId}": {
      "schema": "MatchRound",
      "description": "Scoring rounds"
    }
  }
}
