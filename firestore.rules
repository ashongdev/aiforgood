rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    function isAdmin() {
      return hasRole('ADMIN');
    }

    function isJudge() {
      return hasRole('JUDGE');
    }

    function isOwner(ownerId) {
      return isSignedIn() && request.auth.uid == ownerId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Users ---
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin() || isJudge());
      allow list: if isAdmin() || isJudge();
      
      // User can create their own profile as participant initially
      allow create: if isSignedIn() && request.auth.uid == userId && 
                    incoming().role == 'PARTICIPANT' &&
                    incoming().email == request.auth.token.email;
      
      // Only admins can change roles
      allow update: if isAdmin() || (isOwner(userId) && incoming().role == existing().role);
    }

    // --- Teams ---
    match /teams/{teamId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isEmailVerified() && incoming().ownerId == request.auth.uid;
      allow update: if isAdmin() || isOwner(existing().ownerId);
      allow delete: if isAdmin();
    }

    // --- Rounds ---
    match /rounds/{roundId} {
      allow read: if isSignedIn();
      allow create: if (isAdmin() || isJudge()) && isEmailVerified() && incoming().judgeId == request.auth.uid;
      allow update: if (isAdmin() || isJudge()) && (existing().status != 'FINAL' || isAdmin());
      allow delete: if isAdmin();
    }
  }
}
